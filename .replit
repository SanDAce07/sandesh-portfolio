modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
RESUME_ADMIN_PASSWORD = "PD28Ju3xanBGH67E"

[objectStorage]
defaultBucketID = "replit-objstore-feb1ae17-95d3-449e-8dc2-a1993a16ccb5"
